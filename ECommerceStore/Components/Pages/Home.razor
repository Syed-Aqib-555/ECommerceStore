@page "/"
@rendermode InteractiveServer
@using ECommerceStore.Models
@using ECommerceStore.Services
@inject ProductService ProductService
@inject OrderService OrderService
@inject NavigationManager Navigation

<div class="container-fluid px-4 py-5">

    <!-- Hero Section -->
    <section class="hero-section mb-5">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <span class="hero-badge">WELCOME TO SA STORE</span>

                <h1 class="display-3 fw-bold mt-4 mb-4">
                    Discover Premium
                    <span class="text-gradient">Tech Essentials</span>
                </h1>

                <p class="lead text-light-emphasis mb-4">
                    High-quality gadgets, best prices, and fast delivery.
                    Shop with confidence and style.
                </p>

                <div class="d-flex flex-wrap gap-3 mb-4">
                    <span class="feature-pill">🚚 Fast Delivery</span>
                    <span class="feature-pill">🔒 Secure Payment</span>
                    <span class="feature-pill">⭐ Premium Quality</span>
                </div>
            </div>

            <div class="col-lg-6 text-center">
                <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1000&q=80"
                     class="img-fluid rounded-4 shadow-lg"
                     alt="Tech Products" />
            </div>
        </div>
    </section>

    <!-- Products Heading -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white fw-bold">Featured Products</h2>
        <span class="text-primary">Premium Collection</span>
    </div>

    <!-- Product Cards -->
    <div class="row g-4">
        @foreach (var product in products)
        {
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="card product-card h-100">

                    <img src="@product.ImageUrl"
                         class="card-img-top"
                         alt="@product.Name"
                         style="height:220px; object-fit:cover;" />

                    <div class="card-body d-flex flex-column p-4">
                        <span class="product-badge mb-3">Best Seller</span>

                        <h4 class="text-white fw-bold mb-2">
                            @product.Name
                        </h4>

                        <p class="text-secondary mb-4">
                            Premium quality technology product.
                        </p>

                        <h3 class="price-text mb-4">
                            Rs. @product.Price.ToString("N0")
                        </h3>

                        <button type="button"
                                class="btn btn-order mt-auto"
                                @onclick="() => OrderNow(product)">
                            🛒 Order Now
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Features -->
    <section class="mt-5 pt-5">
        <div class="row g-4">
            <div class="col-md-3">
                <div class="feature-box">🚚 Fast Delivery</div>
            </div>
            <div class="col-md-3">
                <div class="feature-box">🔒 Secure Payments</div>
            </div>
            <div class="col-md-3">
                <div class="feature-box">⭐ Premium Quality</div>
            </div>
            <div class="col-md-3">
                <div class="feature-box">📞 24/7 Support</div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer-section mt-5">
        <div class="row">
            <div class="col-md-4">
                <h4 class="text-white fw-bold">SA Store</h4>
                <p class="text-secondary">
                    Premium Tech, Premium You.
                </p>
            </div>

            <div class="col-md-4">
                <h5 class="text-white">Quick Links</h5>
                <p><a href="/" class="footer-link">Home</a></p>
                <p><a href="/orderconfirmed" class="footer-link">Orders</a></p>
            </div>

            <div class="col-md-4">
                <h5 class="text-white">Contact</h5>
                <p class="text-secondary">📞 +92 300 1234567</p>
                <p class="text-secondary">✉️ support@sastore.com</p>
            </div>
        </div>

        <hr class="border-secondary my-4" />

        <p class="text-center text-secondary mb-0">
            © 2026 SA Store. All Rights Reserved.
        </p>
    </footer>
</div>

@code {
    private List<Product> products = new();

    protected override void OnInitialized()
    {
        products = ProductService.GetProducts();
    }

    private void OrderNow(Product product)
    {
        OrderService.SetSelectedProduct(product);
        Navigation.NavigateTo("/orderform");
    }
}