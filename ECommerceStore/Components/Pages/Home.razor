@page "/"
@rendermode InteractiveServer
@using ECommerceStore.Models
@using ECommerceStore.Services
@inject ProductService ProductService
@inject OrderService OrderService
@inject NavigationManager Navigation

<div class="container py-5">

    <!-- Hero Banner -->
    <section class="hero-section text-center mb-5">
        <span class="badge bg-light text-dark px-3 py-2 rounded-pill mb-3">
            Trusted Technology Store
        </span>

        <h1 class="display-4 fw-bold mb-3">
            Premium Gadgets for Modern Life
        </h1>

        <p class="lead mb-4">
            Shop laptops, smartphones, headphones, and smart watches
            with secure ordering and fast delivery.
        </p>

        <div class="d-flex flex-wrap justify-content-center gap-3">
            <span class="badge bg-success px-4 py-2 rounded-pill">🚚 Fast Delivery</span>
            <span class="badge bg-info text-dark px-4 py-2 rounded-pill">🔒 Secure Ordering</span>
            <span class="badge bg-warning text-dark px-4 py-2 rounded-pill">⭐ Premium Quality</span>
        </div>
    </section>

    <!-- Products Heading -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">Featured Products</h2>
        <p class="text-muted fs-5">
            Carefully selected technology products at competitive prices.
        </p>
    </div>

    <!-- Product Grid -->
    <div class="row g-4">
        @foreach (var product in products)
        {
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="card h-100">

                    <img src="@product.ImageUrl"
                         alt="@product.Name"
                         class="card-img-top"
                         style="height:220px;" />

                    <div class="card-body d-flex flex-column text-center p-4">
                        <h5 class="card-title fw-bold mb-3">@product.Name</h5>

                        <p class="text-muted small mb-4">
                            Premium quality product with excellent performance.
                        </p>

                        <div class="mb-4">
                            <span class="badge bg-success fs-6 px-4 py-2 rounded-pill">
                                Rs. @product.Price.ToString("N0")
                            </span>
                        </div>

                        <button type="button"
                                class="btn btn-primary btn-lg w-100 mt-auto"
                                @onclick="() => OrderNow(product)">
                            🛍️ Order Now
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<footer class="mt-5 pt-5 pb-4">
    <div class="container text-center">
        <h4 class="fw-bold mb-3">🛒 E-Commerce Store</h4>
        <p class="text-light">
            Your trusted destination for premium gadgets and accessories.
        </p>
        <hr class="border-secondary my-4" />
        <p class="mb-0 text-light">
            © 2026 E-Commerce Store. All Rights Reserved.
        </p>
    </div>
</footer>

@code {
    private List<Product> products = new();

    protected override void OnInitialized()
    {
        products = ProductService.GetProducts();
    }

    private void OrderNow(Product product)
    {
        OrderService.SetSelectedProduct(product);
        Navigation.NavigateTo("/orderform");
    }
}