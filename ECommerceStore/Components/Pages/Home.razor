@page "/"
@using ECommerceStore.Models
@using ECommerceStore.Services
@inject ProductService ProductService
@inject OrderService OrderService
@inject NavigationManager Navigation

<div class="container py-5">

    <!-- Hero Section -->
    <div class="bg-primary text-white rounded-4 shadow-lg p-5 mb-5 text-center">
        <h1 class="display-4 fw-bold">🛒 E-Commerce Store</h1>
        <p class="lead mb-0">
            Premium products at the best prices.
        </p>
    </div>

    <!-- Section Heading -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">Featured Products</h2>
        <p class="text-muted">
            Browse our collection and place your order instantly.
        </p>
    </div>

    <!-- Product Cards -->
    <div class="row g-4">
        @foreach (var product in products)
        {
            <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">
                <div class="card h-100 border-0 shadow rounded-4 overflow-hidden">

                    <!-- Product Image -->
                    <img src="@product.ImageUrl"
                         alt="@product.Name"
                         class="card-img-top"
                         style="height: 220px; object-fit: cover;" />

                    <!-- Card Body -->
                    <div class="card-body d-flex flex-column text-center p-4">

                        <!-- Product Name -->
                        <h5 class="card-title fw-bold mb-3">
                            @product.Name
                        </h5>

                        <!-- Product Price -->
                        <div class="mb-4">
                            <span class="badge bg-success fs-6 px-3 py-2 rounded-pill">
                                Rs. @product.Price.ToString("N0")
                            </span>
                        </div>

                        <!-- Order Button -->
                        <button class="btn btn-primary btn-lg rounded-pill mt-auto w-100"
                                @onclick="() => OrderNow(product)">
                            🛍️ Order Now
                        </button>
                    </div>

                </div>
            </div>
        }
    </div>

    <!-- Footer -->
    <div class="text-center mt-5 pt-4 border-top">
        <p class="text-muted mb-0">
            © 2026 E-Commerce Store | Built with Blazor Server & Bootstrap
        </p>
    </div>
</div>

@code {
    private List<Product> products = new();

    protected override void OnInitialized()
    {
        products = ProductService.GetProducts();
    }

    private void OrderNow(Product product)
    {
        OrderService.SetSelectedProduct(product);
        Navigation.NavigateTo("/orderform");
    }
}