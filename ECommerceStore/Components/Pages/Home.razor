@page "/"
@rendermode InteractiveServer
@using ECommerceStore.Models
@using ECommerceStore.Services
@inject ProductService ProductService
@inject OrderService OrderService
@inject NavigationManager Navigation

<div class="container mt-5">

    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">🛒 E-Commerce Store</h1>
        <p class="lead text-muted">
            Browse our products and place your order online.
        </p>
    </div>

    <!-- Product Grid -->
    <div class="row">
        @foreach (var product in products)
        {
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="card h-100 shadow border-0">

                    <!-- Product Image -->
                    <img src="@product.ImageUrl"
                         class="card-img-top"
                         alt="@product.Name"
                         style="height:200px; object-fit:cover;" />

                    <!-- Product Details -->
                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title fw-bold">
                            @product.Name
                        </h5>

                        <p class="text-success fw-bold fs-5">
                            Rs. @product.Price.ToString("N0")
                        </p>

                        <button type="button"
                                class="btn btn-primary mt-auto w-100"
                                @onclick="() => OrderNow(product)">
                            Order Now
                        </button>
                    </div>

                </div>
            </div>
        }
    </div>

</div>

@code {
    private List<Product> products = new();

    protected override void OnInitialized()
    {
        products = ProductService.GetProducts();
    }

    private void OrderNow(Product product)
    {
        OrderService.SetSelectedProduct(product);
        Navigation.NavigateTo("/orderform");
    }
}