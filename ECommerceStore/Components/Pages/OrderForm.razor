@page "/orderform"
@rendermode InteractiveServer
@using ECommerceStore.Models
@using ECommerceStore.Services
@inject OrderService OrderService
@inject NavigationManager Navigation

<div class="container mt-5">

    @if (selectedProduct == null)
    {
        <div class="alert alert-warning">
            No product selected.
        </div>
    }
    else
    {
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0">🛒 Complete Your Order</h3>
            </div>

            <div class="card-body p-4">

                <!-- Selected Product -->
                <div class="alert alert-info">
                    <strong>Selected Product:</strong> @selectedProduct.Name
                    <br />
                    <strong>Price:</strong> Rs. @selectedProduct.Price.ToString("N0")
                </div>

                <!-- Customer Name -->
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control"
                               @bind-Value="order.CustomerName" />
                </div>

                <!-- Address -->
                <div class="mb-3">
                    <label class="form-label">Address</label>
                    <InputText class="form-control"
                               @bind-Value="order.Address" />
                </div>

                <!-- Contact Number -->
                <div class="mb-3">
                    <label class="form-label">Contact Number</label>
                    <InputText class="form-control"
                               @bind-Value="order.ContactNumber" />
                </div>

                <!-- Quantity -->
                <div class="mb-4">
                    <label class="form-label">Quantity</label>
                    <InputNumber class="form-control"
                                 @bind-Value="order.Quantity" />
                </div>

                <!-- Place Order Button -->
                <button class="btn btn-success btn-lg w-100"
                        @onclick="PlaceOrder">
                    ✅ Place Order
                </button>

            </div>
        </div>
    }

</div>

@code {
    private Product? selectedProduct;
    private Order order = new()
    {
        Quantity = 1
    };

    protected override void OnInitialized()
    {
        selectedProduct = OrderService.GetSelectedProduct();

        if (selectedProduct != null)
        {
            order.Product = selectedProduct;
        }
    }

    private void PlaceOrder()
    {
        if (selectedProduct == null)
            return;

        // Ensure product is assigned
        order.Product = selectedProduct;

        // Save order
        OrderService.PlaceOrder(order);

        // Navigate to confirmation page
        Navigation.NavigateTo("/orderconfirmed");
    }
}